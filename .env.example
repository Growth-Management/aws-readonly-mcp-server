# AWS authentication
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ROLE_ARN=
AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=123456789012
AWS_EXTERNAL_ID=
AWS_ROLE_SESSION_NAME=aws-readonly-mcp

# MCP server auth
MCP_AUTH_TOKEN=replace-with-your-secure-random-token
MCP_BASE_URL=https://your-mcp-server.example.com

# App settings
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_LOOKBACK_MONTHS=6
ENABLED_SERVICES=s3,cost-explorer,cloudwatch,config,access-analyzer,cloudtrail

# Optional feature flags
USE_S3_STORAGE_LENS=true
USE_S3_INVENTORY=true
USE_CLOUDTRAIL_DATA_EVENTS=true
USE_SERVER_ACCESS_LOGS=false

# GitHub Actions / deployment metadata
GITHUB_REPOSITORY=your-org/aws-readonly-mcp-server

# Optional encryption / secret references
KMS_KEY_ID=

# Cloud Run deployment
GCP_PROJECT_ID=sysmgmt-cloudrun-bridge
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=aws-readonly-mcp-server
DEPLOY_TARGET=cloud-run
WORKLOAD_IDENTITY_PROVIDER=projects/PROJECT_NUMBER/locations/global/workloadIdentityPools/POOL_ID/providers/PROVIDER_ID
GCP_SERVICE_ACCOUNT=github-deployer@sysmgmt-cloudrun-bridge.iam.gserviceaccount.com
CLOUD_RUN_BASE_URL=
